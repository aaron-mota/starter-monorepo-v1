{
  "name": "starter-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\" --ignore-path .prettierignore",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:run": "turbo test:run",
    "check": "pnpm lint && pnpm format:check && pnpm type-check && pnpm test:run",
    "db:indexes": "tsx packages/db/src/indexes.ts",
    "db:setup": "pnpm db:indexes",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.0",
    "globals": "^16.2.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.19.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.32.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "~19.1.10",
      "expo-constants": "18.0.13"
    }
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
