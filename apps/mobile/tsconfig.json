{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@app/shared": [
        "../../packages/shared/schemas/index.ts"
      ],
      "@app/shared/*": [
        "../../packages/shared/*"
      ],
      "@app/trpc": [
        "../../packages/trpc/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "nativewind-env.d.ts",
    "expo-env.d.ts"
  ]
}
