{
  "name": "@starter/shared",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "lint": "eslint schemas/ constants/ types/",
    "lint:fix": "eslint --fix schemas/ constants/ types/",
    "type-check": "tsc --noEmit"
  },
  "main": "./schemas/index.ts",
  "types": "./schemas/index.ts",
  "exports": {
    ".": "./schemas/index.ts",
    "./schemas/*": "./schemas/*.ts",
    "./constants/*": "./constants/*.ts",
    "./types/*": "./types/*.ts"
  },
  "typesVersions": {
    "*": {
      "schemas/*": ["schemas/*"],
      "constants/*": ["constants/*"],
      "types/*": ["types/*"]
    }
  },
  "dependencies": {
    "lucide-react": "^0.513.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "mongodb": "^7.1.0",
    "server-only": "^0.0.1",
    "typescript": "^6.0.0"
  }
}
